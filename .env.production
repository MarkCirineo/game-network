# ArcadeKit Production Environment Variables
# Copy to .env.local on the server or pass via docker-compose

# Public URL of the site (used for SEO metadata)
NEXT_PUBLIC_SITE_URL=https://arcadekit.games

# WebSocket URL (client connects here)
NEXT_PUBLIC_WS_URL=wss://arcadekit.games/ws

# Game server internal URL (Next.js API routes → game server, via Docker network)
GAME_SERVER_INTERNAL_URL=http://gameserver:3001
